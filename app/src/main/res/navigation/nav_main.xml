<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_main"
    app:startDestination="@id/feedFragment">

    <fragment
        android:id="@+id/feedFragment"
        android:name="ru.netology.nmedia.fragment.FeedFragment"
        android:label="fragment_feed"
        tools:layout="@layout/fragment_feed" >
        <action
            android:id="@+id/action_feedFragment_to_newPostFragment2"
            app:destination="@id/newPostFragment2" />
        <action
            android:id="@+id/action_feedFragment_to_cardPostFragment"
            app:destination="@id/cardPostFragment" />
    </fragment>
    <fragment
        android:id="@+id/newPostFragment2"
        android:name="ru.netology.nmedia.fragment.NewPostFragment"
        android:label="fragment_new_post"
        tools:layout="@layout/fragment_new_post" />
    <fragment
        android:id="@+id/cardPostFragment"
        android:name="ru.netology.nmedia.fragment.CardPostFragment"
        android:label="fragment_card_post"
        tools:layout="@layout/fragment_card_post" >
        <action
            android:id="@+id/action_cardPostFragment_to_newPostFragment2"
            app:destination="@id/newPostFragment2" />
        <action
            android:id="@+id/action_cardPostFragment_to_feedFragment2"
            app:destination="@id/feedFragment" />
    </fragment>
</navigation>